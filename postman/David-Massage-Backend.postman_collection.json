{
  "info": {
    "name": "David Massage Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://massage-backend-qvf7.onrender.com/api" },
    { "key": "accessToken", "value": "" },
    { "key": "slotId", "value": "" },
    { "key": "subscriptionId", "value": "" },
    { "key": "bookingId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client{{$timestamp}}@gmail.com\",\n  \"password\": \"StrongPass123!\",\n  \"firstName\": \"Client\",\n  \"lastName\": \"Test\",\n  \"phone\": \"+33600000000\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "POST /auth/register (aliases FR)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client{{$timestamp}}@gmail.com\",\n  \"mot_passe\": \"StrongPass123!\",\n  \"nom\": \"Client Test\",\n  \"numero_tel\": \"+33600000000\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\",\n  \"password\": \"StrongPass123!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "POST /auth/login (aliases FR)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\",\n  \"mot_passe\": \"StrongPass123!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "GET /auth/me",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "POST /auth/logout",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "url": "{{baseUrl}}/auth/logout"
          }
        },
        {
          "name": "POST /auth/reset-password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\"\n}"
            },
            "url": "{{baseUrl}}/auth/reset-password"
          }
        },
        {
          "name": "POST /auth/change-password",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"StrongPass123!\",\n  \"newPassword\": \"NewStrongPass123!\"\n}"
            },
            "url": "{{baseUrl}}/auth/change-password"
          }
        }
      ]
    },
    {
      "name": "Clients",
      "item": [
        {
          "name": "POST /clients/me",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Client\",\n  \"lastName\": \"Test\",\n  \"phone\": \"+33600000000\",\n  \"address\": \"Paris\"\n}"
            },
            "url": "{{baseUrl}}/clients/me"
          }
        },
        {
          "name": "GET /clients/me",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "url": "{{baseUrl}}/clients/me"
          }
        },
        {
          "name": "PUT /clients/me",
          "request": {
            "method": "PUT",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Client\",\n  \"lastName\": \"Updated\",\n  \"phone\": \"+33600000000\",\n  \"address\": \"Bailly\"\n}"
            },
            "url": "{{baseUrl}}/clients/me"
          }
        }
      ]
    },
    {
      "name": "Subscriptions",
      "item": [
        {
          "name": "GET /subscriptions/availability",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/subscriptions/availability"
          }
        },
        {
          "name": "POST /subscriptions",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"limitedOffer\": true\n}"
            },
            "url": "{{baseUrl}}/subscriptions"
          }
        },
        {
          "name": "GET /subscriptions/me",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "url": "{{baseUrl}}/subscriptions/me"
          }
        },
        {
          "name": "PATCH /subscriptions/me/deduct",
          "request": {
            "method": "PATCH",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "url": "{{baseUrl}}/subscriptions/me/deduct"
          }
        }
      ]
    },
    {
      "name": "Slots & Bookings",
      "item": [
        {
          "name": "GET /slots",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/slots?available=true"
          }
        },
        {
          "name": "POST /bookings",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slotId\": \"{{slotId}}\",\n  \"subscriptionId\": \"{{subscriptionId}}\",\n  \"massageType\": \"massage relaxant\"\n}"
            },
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "GET /bookings/me",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "url": "{{baseUrl}}/bookings/me"
          }
        },
        {
          "name": "DELETE /bookings/:id",
          "request": {
            "method": "DELETE",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "url": "{{baseUrl}}/bookings/{{bookingId}}"
          }
        }
      ]
    }
  ]
}
